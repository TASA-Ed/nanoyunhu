{
  "name": "nanoyunhu",
  "version": "0.5.0",
  "description": "NanoYunHu, Headless YunHu.",
  "homepage": "https://www.tasaed.top",
  "bugs": {
    "url": "https://github.com/TASA-Ed/nanoyunhu/issues"
  },
  "license": "AGPL-3.0-or-later",
  "author": "TASA-Ed Studio",
  "contributors": [
    "ccd2s <tasaedem@outlook.com>"
  ],
  "imports": {
    "#/*": "./src/*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TASA-Ed/nanoyunhu.git"
  },
  "bin": "./dist/index.js",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "rolldown -c ./rolldown.config.ts --watch",
    "build": "rolldown -c ./rolldown.config.ts && tsc --noEmit",
    "build:sea": "rolldown -c ./rolldown.sea.config.ts && node --build-sea sea-config.json",
    "build:sea:windows": "rolldown -c ./rolldown.sea.config.ts && node --build-sea sea-config-windows.json",
    "start": "node ./dist/index.js",
    "start:env": "node --env-file=.env ./dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepare": "husky"
  },
  "dependencies": {
    "@fastify/http-proxy": "^11.5.0",
    "@fastify/websocket": "^11.2.0",
    "@satorijs/element": "^3.2.0",
    "@satorijs/protocol": "^1.7.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^6.0.0",
    "protobufjs": "^8.6.4",
    "undici": "^8.5.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/ws": "^8.18.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "rolldown": "1.1.1",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "pnpm oxlint",
      "pnpm oxfmt"
    ]
  },
  "engines": {
    "node": "^22.18.0 || >=24.5.0"
  }
}
