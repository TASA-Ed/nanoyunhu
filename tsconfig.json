{
  "compilerOptions": {
    "target": "ES2025",
    "module": "Preserve",
    "moduleResolution": "bundler",
    "declaration": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "incremental": true,
    "composite": true,
    "skipLibCheck": true
  },
  "include": ["src", "rolldown.config.ts", "rolldown.sea.config.ts", "package.json"],
  "exclude": ["node_modules", "dist"]
}
