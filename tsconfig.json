{
  "compilerOptions": {
    "target": "ES2025",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "dist",
    "allowJs": true,
    "declaration": true,
    "allowImportingTsExtensions": true,
    "emitDeclarationOnly": true,
    "forceConsistentCasingInFileNames": true,
    "useUnknownInCatchVariables": false,
    "noImplicitAny": false,
    "incremental": true,
    "composite": true,
    "skipLibCheck": true
  },
  "include": ["src", "rolldown.config.ts", "rolldown.sea.config.ts", "package.json"],
  "exclude": ["node_modules", "dist"]
}
